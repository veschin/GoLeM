sequence: {
  shape: sequence_diagram

  dev_user: Developer
  ops_glm: "glm\nCLI"
  j_claude: "claude\nsubprocess"
  ex_zai: "Z.AI\nGLM-5"
  db_state: "~/.claude/\nsubagents/"

  dev_user -> ops_glm: "glm run \"prompt\""

  ops_glm -> ops_glm: "load config\n+ validate"
  ops_glm -> db_state: "create job dir"

  agents: {
    label: "loop [max_parallel slots]"

    ops_glm -> ops_glm: "acquire slot\n(flock)"
    ops_glm -> j_claude: "fork + env\ninjection"

    work: {
      label: "loop [agent working]"

      j_claude -> ex_zai: LLM call
      ex_zai -> j_claude: response
      j_claude -> j_claude: "read / edit\nrun / test"
    }

    j_claude -> ops_glm: "exit + JSON"
    ops_glm -> db_state: "stdout, changelog\nraw.json"
    ops_glm -> ops_glm: "release slot"
  }

  ops_glm -> dev_user: "result\n+ exit code"
}
